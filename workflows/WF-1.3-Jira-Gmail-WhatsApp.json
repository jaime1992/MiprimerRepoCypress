              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "ae284026-1979-4c16-9970-7c5f58609a27",
      "name": "Split Issues",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        820,
        220
      ],
      "parameters": {
        "jsCode": "\nconst data   = $input.first().json;\nconst issues = data.issues || [];\n\nconst tasks = issues.map(issue => {\n  const f = issue.fields || {};\n  return {\n    key:      issue.key,\n    summary:  (f.summary || '').substring(0, 120),\n    type:     f.issuetype?.name  || 'Task',\n    status:   f.status?.name     || 'To Do',\n    priority: f.priority?.name   || 'Medium',\n    assignee: f.assignee?.displayName || 'Sin asignar',\n    reporter: f.reporter?.displayName || '',\n    created:  (f.created || '').substring(0, 10),\n    url:      'https://qaprocess1.atlassian.net/browse/' + issue.key,\n    description: (() => {\n      const d = f.description;\n      if (!d) return '';\n      if (typeof d === 'string') return d.substring(0, 200);\n      try {\n        return (d.content||[]).flatMap(b=>(b.content||[]).map(c=>c.text||'')).join(' ').substring(0,200);\n      } catch { return ''; }\n    })(),\n  };\n});\n\nconst fecha = new Date().toLocaleString('es-CL', { timeZone: 'America/Santiago' });\nconst today = new Date().toISOString().split('T')[0];\n\nreturn [{ json: { tasks, total: tasks.length, fecha, date: today } }];\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "441bca19-2213-416e-9f5e-b35e5d9fa82f",
      "name": "Preparar Datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        220
      ],
      "parameters": {
        "jsCode": "\nconst item  = $input.first().json;\nconst tasks = item.tasks || [];\nconst fecha = item.fecha || '';\n\nconst lines = tasks.map(t =>\n  `📋 *${t.key}* — ${t.summary}\\n` +\n  `   Prioridad: ${t.priority} | Asignado: ${t.assignee}\\n` +\n  `   ${t.url}`\n).join('\\n\\n');\n\nconst msg =\n  `🆕 *Nueva Task QA — KAN*\\n` +\n  `Fecha: ${fecha}\\n` +\n  `Total: ${tasks.length} task(s)\\n\\n` +\n  lines;\n\nreturn [{ json: { ...item, mensajeWhatsApp: encodeURIComponent(msg) } }];\n",
        "mode": "runOnceForAllItems"
      }
    },
