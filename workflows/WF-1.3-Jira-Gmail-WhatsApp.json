      "name": "Hay Tasks nuevas?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        600,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "0078a94a-a031-452f-940e-f7740d7b4213",
              "leftValue": "={{ $json.total }}",
              "rightValue": 0,
